<Application x:Class="Buildermark.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:tb="http://www.hardcodet.net/taskbar"
             ShutdownMode="OnExplicitShutdown">
    <Application.Resources>
        <tb:TaskbarIcon x:Key="TrayIcon"
                        IconSource="/Resources/buildermark.ico"
                        ToolTipText="Buildermark"
                        DoubleClickCommand="{x:Static local:App.OpenBuildermarkCommand}"
                        xmlns:local="clr-namespace:Buildermark">
            <tb:TaskbarIcon.ContextMenu>
                <ContextMenu>
                    <MenuItem x:Name="StatusItem" IsEnabled="False" />
                    <Separator />
                    <MenuItem Header="Open Buildermark"
                              InputGestureText="Ctrl+O"
                              Click="OpenBuildermark_Click" />
                    <Separator />
                    <MenuItem Header="Settings..."
                              InputGestureText="Ctrl+,"
                              Click="Settings_Click" />
                    <MenuItem Header="Quit Buildermark"
                              InputGestureText="Ctrl+Q"
                              Click="Quit_Click" />
                </ContextMenu>
            </tb:TaskbarIcon.ContextMenu>
        </tb:TaskbarIcon>
    </Application.Resources>
</Application>
