{
  "manifest_version": 3,
  "name": "Buildermark Conversation Importer",
  "version": "0.1.0",
  "description": "Import coding agent conversations from Claude Cloud and Codex Cloud into Buildermark.",
  "permissions": ["tabs", "storage"],
  "host_permissions": ["http://localhost:7022/*"],
  "content_scripts": [
    {
      "matches": [
        "*://*.claude.ai/chat/*",
        "*://*.claude.ai/project/*/chat/*",
        "*://chatgpt.com/codex/*",
        "*://codex.openai.com/*"
      ],
      "js": ["content/api.js", "content/importer.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://*.claude.ai/code/*"],
      "js": ["content/api.js", "content/claude_code_cloud.js", "content/content.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["web_accessible/fetch_interceptor.js"],
      "matches": ["*://*.claude.ai/*"]
    }
  ],
  "background": {
    "service_worker": "background/background.js"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Buildermark",
    "default_popup": "popup/popup.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
