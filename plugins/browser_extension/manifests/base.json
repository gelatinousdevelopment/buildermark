{
  "manifest_version": 3,
  "name": "Buildermark Importer",
  "version": "1.1.0",
  "description": "Import coding agent conversations from Claude Cloud and Codex Cloud into Buildermark.",
  "permissions": ["storage"],
  "host_permissions": ["http://localhost:55022/*"],
  "content_scripts": [
    {
      "matches": ["*://*.claude.ai/chat/*", "*://*.claude.ai/project/*/chat/*"],
      "js": ["shared/chrome_compat.js", "content/api.js", "content/importer.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://*.claude.ai/code/*", "*://chatgpt.com/codex/*"],
      "js": ["shared/chrome_compat.js", "content/api.js", "content/cloud_listener.js", "content/content.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["web_accessible/fetch_interceptor.js"],
      "matches": ["*://*.claude.ai/*", "*://chatgpt.com/*"]
    }
  ],
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Buildermark",
    "default_popup": "popup/popup.html"
  },
  "icons": {
    "16": "icons/app_icon16.png",
    "32": "icons/app_icon32.png",
    "48": "icons/app_icon48.png",
    "128": "icons/app_icon128.png"
  }
}
